{
  "expo": {
    "name": "Arabian Fal",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6491"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.arabianfal.legal",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Arabian Fal needs access to your photo library to attach images to legal requests.",
        "NSPhotoLibraryAddUsageDescription": "Arabian Fal needs permission to save photos.",
        "NSCameraUsageDescription": "Arabian Fal needs camera access to take photos for legal requests.",
        "UISupportsDocumentBrowser": true,
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "package": "com.arabianfal.legal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#2D6491"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Arabian Fal needs access to your photo library to attach images to legal requests.",
          "cameraPermission": "Arabian Fal needs camera access to take photos for legal requests."
        }
      ],
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
